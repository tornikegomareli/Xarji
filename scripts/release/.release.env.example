# Local release configuration — copy this file to .release.env
# (gitignored) and fill in the values before running build.sh.
#
# Nothing in here is secret in the "password" sense: APP_IDENTITY is
# just the common name of your Developer ID Application certificate
# which is printed freely by `security find-identity`, and
# NOTARY_PROFILE is the label of a Keychain entry that holds the
# actual app-specific password. The real credentials live in the
# Keychain, not on disk.

# Common name of your Developer ID Application certificate, exactly as
# shown by:
#   security find-identity -v -p codesigning
#
# Must already be imported into your login Keychain — you get this
# certificate by enrolling in the Apple Developer Program and
# downloading it from developer.apple.com or by generating one in
# Xcode → Settings → Accounts → Manage Certificates.
APP_IDENTITY="Developer ID Application: Your Name (XXXXXXXXXX)"

# Label of the notarytool Keychain profile. Create it once with:
#
#   xcrun notarytool store-credentials "xarji-notary" \
#     --apple-id you@example.com \
#     --team-id XXXXXXXXXX \
#     --password <app-specific-password>
#
# Generate the app-specific password at https://appleid.apple.com under
# "App-Specific Passwords". notarytool stores it inside Keychain; this
# variable just names which entry to read on each notarize run.
NOTARY_PROFILE="xarji-notary"

# Apple team id (10-char alphanumeric). Used only for DMG volume name
# hints; not required by notarytool (it reads it from the profile).
APPLE_TEAM_ID="XXXXXXXXXX"
